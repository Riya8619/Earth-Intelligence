APP_NAME=Earth Intelligence X
APP_ENV=development
DEBUG=True

SECRET_KEY=change-this-secret-key
ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Local dev default. On Render, set this to the Postgres connection string
# (postgresql://...) provided by your database. It is automatically
# normalized to use the psycopg (v3) driver.
DATABASE_URL=sqlite:///./earth_intel_x.db

# URL of the deployed frontend (Vercel), used for CORS.
FRONTEND_URL=http://localhost:5174

# AI provider 
GROQ_API_KEY=

# External data sources
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
NASA_API_KEY=
NASA_FIRMS_API_KEY=
USGS_API_URL=https://earthquake.usgs.gov/fdsnws/event/1/query
GDACS_API_URL=https://www.gdacs.org/gdacsapi/api/events/geteventlist
